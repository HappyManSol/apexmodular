# Formspree form ID — create a form at https://formspree.io and paste the ID here.
# Also add NEXT_PUBLIC_FORMSPREE_FORM_ID in Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_FORMSPREE_FORM_ID=

# Analytics (optional — enable one or both in Vercel)
# Plausible: add your domain as registered in plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=apexmodularplates.com
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
